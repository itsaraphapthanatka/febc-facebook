{
  "name": "febc-facebook",
  "version": "0.1.0",
  "description": "Middleware for Facebook Page management, multi-page broadcast, and LLM auto-post scheduling",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:push": "drizzle-kit push",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.2",
    "@fastify/static": "^8.3.0",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "fastify": "^5.3.2",
    "fastify-raw-body": "^5.0.0",
    "node-cron": "^3.0.3",
    "openai": "^4.104.0",
    "pg": "^8.16.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.15.0",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.4"
  }
}
